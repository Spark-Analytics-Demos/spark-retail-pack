# =============================================================================
# SQLFluff configuration — spark_retail_pack
# Dialect: Snowflake | Templater: jinja
#
# Using jinja templater (not dbt) so lint runs without a Snowflake connection.
# This is appropriate for CI style checks. If macro-aware linting is needed
# locally, switch templater to 'dbt' and run: sqlfluff lint --target dev
# =============================================================================

[sqlfluff]
templater = jinja
dialect = snowflake
# Enforce a consistent line ending
output_line_length = 120

# Rules excluded for this project:
# RF04 — single-char aliases are fine in date spines and cross joins
# AL05 — aliases on subqueries are optional; we allow omitting them
exclude_rules = RF04, AL05

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
indented_joins = false
indented_ctes = false
template_blocks_indent = false

# ---------------------------------------------------------------------------
# Capitalisation rules — Snowflake convention: UPPER keywords, lower identifiers
# ---------------------------------------------------------------------------
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
# dbt model names and column aliases are lowercase snake_case
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper

# ---------------------------------------------------------------------------
# Aliasing rules — always explicit, no implicit AS
# ---------------------------------------------------------------------------
[sqlfluff:rules:aliasing.table]
aliasing = explicit

[sqlfluff:rules:aliasing.column]
aliasing = explicit

# ---------------------------------------------------------------------------
# Layout rules
# ---------------------------------------------------------------------------
[sqlfluff:rules:layout.long_lines]
# Mirror output_line_length
line_length_limit = 120

# ---------------------------------------------------------------------------
# Convention rules
# ---------------------------------------------------------------------------
[sqlfluff:rules:convention.select_trailing_comma]
# Prefer trailing commas (consistent with dbt community style)
select_clause_trailing_comma = require

[sqlfluff:rules:convention.terminator]
# Require semicolons at end of statements
multiline_newline = true
