# =============================================================================
# Spark Retail Pack — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Usage (PowerShell):
#   $env:SF_ACCOUNT        = "your-account-identifier"
#   $env:SF_ADMIN_USER     = "your-admin-username"
#   $env:SF_ADMIN_PASSWORD = "your-admin-password"
#
# Or load all at once with a tool like direnv or dotenv.
# =============================================================================

# ── Snowflake admin (provisioning only) ──────────────────────────────────────
# Used by: setup/snowflake/run_provisioning.py
# Account identifier: found in your Snowflake URL (e.g. abc12345.us-west-2.aws)
# or the new org format (e.g. myorg-myaccount)
SF_ACCOUNT=
SF_ADMIN_USER=
SF_ADMIN_PASSWORD=

# ── Snowflake service accounts (dbt runtime) ─────────────────────────────────
# Used by: dbt profiles.yml (copied from profiles.yml.template)
# Set after running 05_service_accounts.sql and storing credentials.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# CI only — set in GitHub Actions secrets, not locally
# SNOWFLAKE_CI_USER=
# SNOWFLAKE_CI_PASSWORD=

# ── PII hashing salt ──────────────────────────────────────────────────────────
# Used by: pii_mask macro (Section 8.5)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be the same value across all environments that need consistent hashes.
PII_HASH_SALT=
